generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String 

  templates Template[]
  variables Variable[]
}

model Template {
  id   String @id @default(uuid())
  name String

  pages Json @default("[]")

  preview    String? 
  background String? 

  isMaster Boolean @default(false)
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  originTemplateId String?
  originTemplate   Template?  @relation("TemplateOrigin", fields: [originTemplateId], references: [id])
  derivedTemplates Template[] @relation("TemplateOrigin")

  reportInstances ReportInstance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReportInstance {
  id   String @id @default(uuid())
  name String

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  variableSnapshot Json? 

  pages Json @default("[]")

  status String  @default("DRAFT")
  pdfUrl String?
  data   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Variable {
  id    String @id @default(uuid())
  key   String
  label String
  scope String @default("USER")

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
}

model Asset {
  id        String   @id @default(uuid())
  filename  String
  mimetype  String
  filepath  String
  url       String
  createdAt DateTime @default(now())
}

model PdfCache {
  OriginalFileId    String   @id @default(uuid())
  OriginalFile      Boolean  @default(true)
  FileName          String
  OriginalUrlorPath String
  FilePath          String
  EditedFile        Boolean  @default(false)
  TempFilePath      String?
  editState         Json?
  EditedFilePath    String?
  createdAt         DateTime @default(now())
  lastEditAt        DateTime @updatedAt
}

model Signatory {
  id             String   @id @default(uuid())
  fullName       String   
  signatureImage String?  
  variableName   String   @unique
  prefixText     String?  
  position       String?  
  createdAt      DateTime @default(now())
}

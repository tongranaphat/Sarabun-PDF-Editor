generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String 

  variables Variable[]
}

model Variable {
  id    String @id @default(uuid())
  key   String
  label String
  scope String @default("USER")

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
}

model PdfCache {
  OriginalFileId    String   @id @default(uuid())
  OriginalFile      Boolean  @default(true)
  FileName          String
  OriginalUrlorPath String
  FilePath          String
  EditedFile        Boolean  @default(false)
  TempFilePath      String?
  editState         Json?
  EditedFilePath    String?
  createdAt         DateTime @default(now())
  lastEditAt        DateTime @updatedAt
  stampConfig       StampConfig?
}

model Signatory {
  id             String   @id @default(uuid())
  fullName       String   
  signatureImage String?  
  variableName   String   @unique
  prefixText     String?  
  position       String?  
  createdAt      DateTime @default(now())
}

model StampConfig {
  id           String   @id @default(uuid())
  schoolName   String   @default("โรงเรียนทดสอบ")
  seqNo        String
  dateStr      String?
  timeStr      String?
  pdfCacheId   String   @unique
  pdfCache     PdfCache @relation(fields: [pdfCacheId], references: [OriginalFileId], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

